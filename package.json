{
  "name": "workbench",
  "version": "0.1.0",
  "description": "Web-based CLI workbench for AI coding agents",
  "private": true,
  "scripts": {
    "start": "node src/server.js",
    "test": "node --test tests/mock/*.test.js",
    "test:coverage": "c8 --reporter=text --reporter=lcov --lines 80 --branches 70 --include='src/**/*.js' --exclude='tests/**' --exclude='scripts/**' --exclude='public/**' --exclude='node_modules/**' node --test tests/mock/*.test.js",
    "test:live": "MAX_TMUX_SESSIONS=50 node --test --test-concurrency=1 tests/live/*.test.js",
    "test:browser": "node --test-timeout 600000 --test tests/browser/*.test.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/xterm": "6.0.0",
    "better-sqlite3": "11.8.1",
    "chokidar": "4.0.3",
    "express": "4.21.2",
    "jquery": "4.0.0",
    "jqueryfiletree": "2.1.4",
    "node-pty": "1.0.0",
    "simple-git": "3.27.0",
    "ws": "8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "c8": "11.0.0",
    "eslint": "9.17.0",
    "playwright": "1.50.1",
    "prettier": "3.8.2"
  }
}
