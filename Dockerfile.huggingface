FROM node:22-slim

RUN apt-get update && apt-get install -y \
    git curl ca-certificates python3 make g++ tmux ssh openssh-client jq \
    libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 \
    libxkbcommon0 libxcomposite1 libxdamage1 libxrandr2 libgbm1 \
    libpango-1.0-0 libcairo2 libasound2 libxshmfence1 \
    && rm -rf /var/lib/apt/lists/*

# Install Claude CLI and Playwright MCP from public npm
RUN npm install -g @anthropic-ai/claude-code @playwright/mcp
RUN npx playwright install chrome

# Create non-root user matching HF Spaces UID 1000
RUN useradd -m -u 1000 -s /bin/bash hopper && \
    mkdir -p /home/hopper/.claude /home/hopper/.blueprint /data/workspace /data/storage && \
    chown -R hopper:hopper /home/hopper /data

# Copy and install app dependencies
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --omit=dev && chown -R hopper:hopper /app

# Copy app source
COPY --chown=hopper:hopper . .

# Pre-create settings to skip permissions prompt and onboarding
RUN mkdir -p /home/hopper/.claude && \
    echo '{"skipDangerousModePermissionPrompt":true,"hasCompletedOnboarding":true,"theme":"dark","preferredTheme":"dark"}' > /home/hopper/.claude/settings.json && \
    echo '{"skipDangerousModePermissionPrompt":true,"hasCompletedOnboarding":true,"theme":"dark","hasPickedTheme":true,"preferredTheme":"dark"}' > /home/hopper/.claude/settings.local.json && \
    chown -R hopper:hopper /home/hopper

USER hopper

ENV HOME=/home/hopper
ENV CLAUDE_HOME=/home/hopper/.claude
ENV BLUEPRINT_DATA=/data/blueprint
ENV PORT=7860

WORKDIR /data/workspace
EXPOSE 7860

COPY --chown=hopper:hopper entrypoint-hf.sh /entrypoint-hf.sh
ENTRYPOINT ["/entrypoint-hf.sh"]
CMD ["node", "/app/server.js"]
