{
  "session": {
    "nudgeThresholdPercent": 75,
    "resumeTailLines": 60,
    "nameMaxLength": 60,
    "promptInjectionDelayMs": 2000,
    "promptMaxLength": 4096
  },
  "polling": {
    "tokenUsageIntervalMs": 15000
  },
  "keepalive": {
    "refreshPercentLow": 65,
    "refreshPercentHigh": 85,
    "fallbackIntervalMin": 30
  },
  "tmux": {
    "maxSessions": 10,
    "idleWithTabDays": 99999,
    "idleWithoutTabDays": 4,
    "scanIntervalSeconds": 60,
    "windowWidth": 200,
    "windowHeight": 50
  },
  "debug": {
    "tabSwitching": false
  },
  "embeddings": {
    "providers": {
      "huggingface": {
        "url": "https://router.huggingface.co/hf-inference/models/sentence-transformers/all-MiniLM-L6-v2/pipeline/feature-extraction",
        "model": "hf-free"
      },
      "gemini": {
        "url": "https://generativelanguage.googleapis.com/v1beta/openai",
        "model": "gemini-embedding-001"
      },
      "openai": {
        "url": "https://api.openai.com/v1",
        "model": "text-embedding-3-small"
      }
    }
  }
}
